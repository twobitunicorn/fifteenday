# Copy to .env.local and fill in.

# Neon Postgres — provisioned via Vercel Marketplace
DATABASE_URL=

# Anthropic API for interview + drafting + routing
ANTHROPIC_API_KEY=

# Resend — transactional email + inbound webhook
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Inbound email domain (e.g. inbound.fifteenday.org). Replies are routed to
# req-<request-id>@${INBOUND_DOMAIN}. Configure MX records to point at Resend.
INBOUND_DOMAIN=

# Outbound "from" address. Must be on a verified Resend domain.
OUTBOUND_FROM_EMAIL=requests@fifteenday.org

# Vercel Blob — stores response PDFs
BLOB_READ_WRITE_TOKEN=

# Admin password for the publish-toggle (single-user gate, v1).
# A long random string. Replace with magic-link auth in Phase D.
ADMIN_PASSWORD=
